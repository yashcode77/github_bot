NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

JWT_SECRET=replace_with_at_least_32_random_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# 32-byte key encoded as 64 hex characters: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_character_hex_string

SESSION_SECRET=replace_with_at_least_32_random_characters
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
# For local webhook testing, expose the backend with ngrok and use the HTTPS URL here:
# BACKEND_URL=https://your-subdomain.ngrok-free.app
GITHUB_WEBHOOK_SECRET=replace_with_at_least_32_random_characters
